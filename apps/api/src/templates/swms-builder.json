{
  "tradeType": "builder",
  "version": "1.0",
  "nzRegulations": [
    "Health and Safety at Work Act 2015",
    "Building Act 2004",
    "Construction Contracts Act 2002",
    "WorkSafe NZ Construction Guidance"
  ],
  "sections": [
    {
      "id": "scope",
      "title": "Scope of Work",
      "fields": [
        {
          "id": "jobDescription",
          "type": "text",
          "label": "Job Description",
          "placeholder": "Describe the construction/building work",
          "required": true
        },
        {
          "id": "location",
          "type": "text",
          "label": "Site Address",
          "required": true
        },
        {
          "id": "clientName",
          "type": "text",
          "label": "Client Name",
          "required": true
        },
        {
          "id": "duration",
          "type": "select",
          "label": "Expected Duration",
          "options": ["< 1 day", "1-3 days", "1-2 weeks", "1 month+"],
          "required": true
        },
        {
          "id": "workType",
          "type": "checklist",
          "label": "Type of Work",
          "options": [
            "New build",
            "Renovation",
            "Demolition",
            "Roofing",
            "Framing",
            "Foundation work",
            "Cladding",
            "Interior fit-out",
            "Decking",
            "Fencing"
          ]
        },
        {
          "id": "buildingConsent",
          "type": "text",
          "label": "Building Consent Number (if applicable)"
        }
      ]
    },
    {
      "id": "hazards",
      "title": "Hazard Identification",
      "aiAssisted": true,
      "fields": [
        {
          "id": "constructionHazards",
          "type": "checklist",
          "label": "Construction-Specific Hazards",
          "options": [
            "Working at height (>3m)",
            "Roof work",
            "Scaffolding",
            "Ladder use",
            "Excavation/trenching",
            "Falling objects",
            "Structural collapse",
            "Demolition hazards",
            "Concrete work",
            "Formwork/falsework"
          ]
        },
        {
          "id": "materialHazards",
          "type": "checklist",
          "label": "Material Hazards",
          "options": [
            "Asbestos (pre-2000 buildings)",
            "Lead paint",
            "Treated timber chemicals",
            "Dust (wood, concrete, silica)",
            "Adhesives/solvents",
            "Fibreglass insulation",
            "Heavy materials (manual handling)"
          ]
        },
        {
          "id": "equipmentHazards",
          "type": "checklist",
          "label": "Equipment Hazards",
          "options": [
            "Power tools (saws, drills, nail guns)",
            "Pneumatic tools",
            "Mobile plant (excavators, forklifts)",
            "Cranes/lifting equipment",
            "Electrical tools",
            "Hand tools",
            "Compressors"
          ]
        },
        {
          "id": "siteHazards",
          "type": "checklist",
          "label": "Site Hazards",
          "options": [
            "Underground services",
            "Overhead power lines",
            "Traffic management",
            "Public access nearby",
            "Uneven ground",
            "Temporary structures",
            "Weather exposure"
          ]
        },
        {
          "id": "otherHazards",
          "type": "textarea",
          "label": "Other Identified Hazards"
        }
      ]
    },
    {
      "id": "controls",
      "title": "Risk Controls",
      "aiAssisted": true,
      "fields": [
        {
          "id": "heightControls",
          "type": "textarea",
          "label": "Working at Height Controls",
          "defaultValue": "For work above 3 metres:\n1. Use scaffolding with guardrails where possible\n2. If scaffolding not practical, use harness with anchor point\n3. Secure all tools and materials to prevent falling\n4. Install edge protection on open edges\n5. Ensure ladder use follows 4:1 rule and 1m above landing"
        },
        {
          "id": "ppe",
          "type": "checklist",
          "label": "PPE Required",
          "options": [
            "Hard hat (AS/NZS 1801)",
            "Safety glasses/goggles",
            "Hi-vis clothing",
            "Steel-cap boots",
            "Hearing protection",
            "Dust mask (P2 minimum)",
            "Work gloves",
            "Fall arrest harness",
            "Sun protection (hat, sunscreen)",
            "Respirator (for specific hazards)"
          ]
        },
        {
          "id": "siteControls",
          "type": "checklist",
          "label": "Site Controls",
          "options": [
            "Site fencing/hoarding",
            "Signage in place",
            "First aid kit on site",
            "Fire extinguisher on site",
            "Toilet facilities",
            "Secure storage for materials",
            "Traffic management plan",
            "Emergency exits clear",
            "Site register maintained"
          ]
        },
        {
          "id": "emergencyPlan",
          "type": "textarea",
          "label": "Emergency Response Plan",
          "required": true,
          "defaultValue": "Fall from Height:\n1. Do not move person unless immediate danger\n2. Call 111 immediately\n3. Keep person warm and calm\n4. Do not remove hard hat if head injury suspected\n\nStructural Collapse:\n1. Evacuate area immediately\n2. Call 111\n3. Account for all workers\n4. Do not re-enter until cleared by authorities\n\nNearest hospital: [To be filled]\nFirst aid kit location: [To be filled]\nAssembly point: [To be filled]"
        }
      ]
    },
    {
      "id": "permits",
      "title": "Permits & Notifications",
      "fields": [
        {
          "id": "lbpNumber",
          "type": "text",
          "label": "LBP Number (Licensed Building Practitioner)"
        },
        {
          "id": "siteSafe",
          "type": "checkbox",
          "label": "Site Safe certification valid"
        },
        {
          "id": "worksafeNotification",
          "type": "checkbox",
          "label": "WorkSafe notifiable work notification submitted (if applicable)"
        },
        {
          "id": "excavationPermit",
          "type": "checkbox",
          "label": "Excavation permit obtained (if over 1.5m deep)"
        },
        {
          "id": "scaffoldingCert",
          "type": "checkbox",
          "label": "Scaffolding erected by competent person"
        }
      ]
    },
    {
      "id": "signoff",
      "title": "Sign-off",
      "fields": [
        {
          "id": "workerDeclaration",
          "type": "checkbox",
          "label": "I have read and understood this SWMS, and agree to follow the safe work procedures outlined",
          "required": true
        },
        {
          "id": "workerName",
          "type": "text",
          "label": "Worker Name",
          "required": true
        },
        {
          "id": "workerSignature",
          "type": "signature",
          "label": "Worker Signature",
          "required": true
        },
        {
          "id": "workerDate",
          "type": "date",
          "label": "Date",
          "required": true
        },
        {
          "id": "supervisorSignature",
          "type": "signature",
          "label": "Site Supervisor Signature"
        }
      ]
    }
  ],
  "aiPrompts": {
    "hazardSuggestions": "You are a NZ workplace health and safety expert specializing in construction and building work. Given the job description, suggest specific hazards considering NZ regulations (Health and Safety at Work Act 2015, Building Act 2004, WorkSafe construction guidance). Consider the specific type of building work described.",
    "controlSuggestions": "You are a NZ workplace health and safety expert. For each construction hazard, provide specific control measures following the hierarchy of controls. Reference NZ building standards, Site Safe requirements, and WorkSafe guidance where applicable."
  }
}
