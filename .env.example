# TradeMate NZ Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=trademate
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=trademate
DATABASE_URL=postgresql://trademate:your-secure-password-here@localhost:29432/trademate

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:29379

# =============================================================================
# API SERVER
# =============================================================================
API_PORT=29000
NODE_ENV=development
LOG_LEVEL=debug

# =============================================================================
# AUTHENTICATION
# =============================================================================
JWT_SECRET=generate-32-char-random-string-here
JWT_EXPIRY=7d
MAGIC_LINK_SECRET=generate-another-32-char-random-string

# =============================================================================
# AI - ANTHROPIC
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# XERO INTEGRATION (Module 2)
# =============================================================================
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=http://localhost:29000/auth/xero/callback

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_BASIC=price_basic_monthly
STRIPE_PRICE_ID_PRO=price_pro_monthly

# =============================================================================
# TWILIO SMS
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+64xxxxxxxxx

# =============================================================================
# FILE STORAGE
# =============================================================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# For S3:
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=trademate-documents
# AWS_REGION=ap-southeast-2

# =============================================================================
# MOBILE APP
# =============================================================================
API_URL=http://localhost:29000
# Production: https://api.trademate.nz

# =============================================================================
# CORTEXFORGE INTEGRATION
# =============================================================================
CORTEXFORGE_API_URL=http://localhost:28000
CORTEXFORGE_PROJECT_ID=trademate-nz
