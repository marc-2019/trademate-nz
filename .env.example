# BossBoard Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# APP BRANDING (configurable — no hardcoded product names in code)
# =============================================================================
APP_NAME=BossBoard
APP_DOMAIN=

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=bossboard
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=bossboard
DATABASE_URL=postgresql://bossboard:your-secure-password-here@localhost:29432/bossboard

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:29379

# =============================================================================
# API SERVER
# =============================================================================
PORT=29000
NODE_ENV=development

# CORS (comma-separated origins for mobile/web clients)
# CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000

# =============================================================================
# AUTHENTICATION (JWT)
# =============================================================================
JWT_SECRET=generate-32-char-random-string-here
JWT_REFRESH_SECRET=generate-another-32-char-random-string-here

# =============================================================================
# AI - ANTHROPIC
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# =============================================================================
# EMAIL (Resend — https://resend.com)
# =============================================================================
RESEND_API_KEY=re_your-resend-api-key-here
# Display name and from address used in outgoing emails
SMTP_FROM_NAME=BossBoard
SMTP_FROM_EMAIL=noreply@yourdomain.co.nz

# =============================================================================
# XERO INTEGRATION (Module 2 — future)
# =============================================================================
# XERO_CLIENT_ID=your-xero-client-id
# XERO_CLIENT_SECRET=your-xero-client-secret
# XERO_REDIRECT_URI=http://localhost:29000/auth/xero/callback

# =============================================================================
# STRIPE PAYMENTS (Phase B — ~50 beta users)
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# STRIPE_PRICE_ID_TRADIE=price_tradie_weekly
# STRIPE_PRICE_ID_TEAM=price_team_weekly

# =============================================================================
# TWILIO SMS (future)
# =============================================================================
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+64xxxxxxxxx

# =============================================================================
# FILE STORAGE
# =============================================================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# For S3 (production):
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=bossboard-documents
# AWS_REGION=ap-southeast-2

# =============================================================================
# MOBILE APP
# =============================================================================
API_URL=http://localhost:29000
# Production: https://api.yourdomain.co.nz
