{
  "name": "@bossboard/shared",
  "version": "0.5.0",
  "description": "Shared types, theme, and utilities for BossBoard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./theme": {
      "import": "./dist/theme/colors.js",
      "types": "./dist/theme/colors.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/format.js",
      "types": "./dist/utils/format.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
