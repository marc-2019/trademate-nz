# =============================================================================
# Production Environment Configuration
# =============================================================================
#
# INSTRUCTIONS:
#   For Railway: Set these as Environment Variables in Railway dashboard.
#                Railway auto-injects DATABASE_URL and REDIS_URL from plugins.
#   For Docker:  Copy to .env.production and fill in values.
#
#   Generate secrets with: openssl rand -base64 48
#   NEVER commit real credentials to version control.
#
# =============================================================================

# =============================================================================
# APP BRANDING (configurable - name/domain not finalised yet)
# =============================================================================
APP_NAME=BossBoard
APP_DOMAIN=https://your-domain.com

# =============================================================================
# NODE / APP
# =============================================================================
NODE_ENV=production
# Railway injects PORT automatically. For Docker, default is 29000.
# PORT=29000

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
# Railway: Auto-injected from PostgreSQL plugin. No need to set.
# Docker:  Set to your PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# =============================================================================
# CACHE - Redis
# =============================================================================
# Railway: Auto-injected from Redis plugin. No need to set.
# Docker:  Set to your Redis connection string.
REDIS_URL=redis://host:6379

# =============================================================================
# AUTHENTICATION - JWT
# =============================================================================
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_USE_openssl_rand_base64_48_DIFFERENT

# =============================================================================
# AI - ANTHROPIC CLAUDE
# =============================================================================
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# =============================================================================
# CORS - Allowed Origins
# =============================================================================
# Comma-separated list of allowed origins (your mobile app, web frontend, etc.)
CORS_ORIGINS=https://your-domain.com

# =============================================================================
# EMAIL - SMTP (for invoice emails, verification codes)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM_NAME=Your App Name
SMTP_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# STRIPE PAYMENTS (NZ) - Phase B, not needed yet
# =============================================================================
# STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
# STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# STRIPE_PRICE_ID_TRADIE=price_CHANGE_ME
# STRIPE_PRICE_ID_TEAM=price_CHANGE_ME

# =============================================================================
# FILE STORAGE
# =============================================================================
STORAGE_TYPE=local
STORAGE_PATH=/app/uploads

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
