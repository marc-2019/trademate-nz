{
  "name": "bossboard",
  "version": "0.5.0",
  "private": true,
  "description": "Mobile-first compliance and cashflow platform for NZ tradies",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace=apps/api",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace=apps/api",
    "test:mobile": "npm run test --workspace=apps/mobile",
    "test:coverage": "npm run test:coverage --workspace=apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "bossboard",
    "nz",
    "tradies",
    "compliance",
    "swms",
    "cashflow"
  ],
  "author": "Instilligent Limited",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "semver": "^7.7.2",
    "handlebars": "^4.7.9",
    "lodash": "^4.17.21",
    "node-forge": "^1.3.3",
    "path-to-regexp": "^0.1.13",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3",
    "xml2js": "^0.6.2",
    "@xmldom/xmldom": "^0.8.12",
    "xmldom": "^0.6.0",
    "brace-expansion": "^2.0.3",
    "@tootallnate/once": "^3.0.1"
  }
}
