# BossBoard Web - Multi-stage Dockerfile
# Builds Expo web export and serves via nginx

# =============================================================================
# BASE STAGE - Install dependencies
# =============================================================================
FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache python3 make g++

# Copy workspace root files
COPY package.json package-lock.json ./
COPY apps/mobile/package.json apps/mobile/
COPY apps/api/package.json apps/api/

# Install all dependencies (needed for monorepo resolution)
RUN npm ci --ignore-scripts 2>/dev/null || npm install --ignore-scripts

# =============================================================================
# BUILDER STAGE - Build Expo web export
# =============================================================================
FROM base AS builder
WORKDIR /app

# Copy mobile app source
COPY apps/mobile/ apps/mobile/

# Set API URL to empty so it uses relative paths (nginx will proxy)
ENV EXPO_PUBLIC_API_URL=""

# Build the web export
WORKDIR /app/apps/mobile
RUN npx expo export --platform web 2>&1

# =============================================================================
# PRODUCTION STAGE - Serve with nginx
# =============================================================================
FROM nginx:1.25-alpine AS production

# Copy nginx config
COPY nginx/bossboard-web.conf /etc/nginx/conf.d/default.conf

# Copy built web files
COPY --from=builder /app/apps/mobile/dist /usr/share/nginx/html

# Inject Google Analytics 4 tag (Measurement ID: G-83NPHN0QP5)
RUN sed -i 's|</head>|<!-- Google tag (gtag.js) -->\n<script async src="https://www.googletagmanager.com/gtag/js?id=G-83NPHN0QP5"></script>\n<script>\nwindow.dataLayer = window.dataLayer \|\| [];\nfunction gtag(){dataLayer.push(arguments);}\ngtag("js", new Date());\ngtag("config", "G-83NPHN0QP5");\n</script>\n</head>|' /usr/share/nginx/html/index.html

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
